{
  "name": "servemyapi",
  "version": "1.0.0",
  "description": "Personal MCP server for securely storing and accessing API keys across projects using the macOS Keychain",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "api-key": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "cli": "node dist/cli.js"
  },
  "keywords": [
    "mcp",
    "api",
    "keychain",
    "macos"
  ],
  "author": "James King",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "cookie-parser": "^1.4.7",
    "express": "^5.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.4",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "jest": "^30.0.4",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.4.11"
  }
}
